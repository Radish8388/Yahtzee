<Window x:Class="Yahtzee.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Yahtzee"
        mc:Ignorable="d"
        Title="Stats"
        Height="700" Width="600"
        WindowStartupLocation="CenterOwner"
        ContentRendered="Window_ContentRendered">
    <Grid x:Name="OuterGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="12*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- 1st row -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Number of completed games:"
                   TextWrapping="Wrap" FontSize="16"
                   HorizontalAlignment="Right"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"/>

        <!-- 2nd row -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Average score:"
                   TextWrapping="Wrap" FontSize="16"
                   HorizontalAlignment="Right"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"/>

        <!-- 3rd row -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Score in last game:"
                   TextWrapping="Wrap" FontSize="16"
                   HorizontalAlignment="Right"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"/>

        <!-- 4th row -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Date of last game:"
                   TextWrapping="Wrap" FontSize="16"
                   HorizontalAlignment="Right"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"/>

        <!-- 5th row -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Low score:"
                   TextWrapping="Wrap" FontSize="16"
                   HorizontalAlignment="Right"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"/>

        <!-- 6th row -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Date of low score:"
                   TextWrapping="Wrap" FontSize="16"
                   HorizontalAlignment="Right"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"/>

        <!-- 7th row -->
        <Grid x:Name="InnerGrid" Grid.Row="6" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="High Scores" FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Rank" FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="Score" FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Date" FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- 8th row -->
        <Button Grid.Row="7" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Click="ResetButton_Click" Width="50">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Reset" />
                <TextBlock Text="Stats" />
            </StackPanel>
        </Button>
        <Button Grid.Row="7" Grid.Column="1" Content="OK" IsDefault="True" HorizontalAlignment="Center" VerticalAlignment="Center" Click="okButton_Click" Width="50"/>
    </Grid>
</Window>
